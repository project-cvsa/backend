<file path="package.json">
{
	"name": "@cvsa/db",
	"type": "module",
	"module": "index.ts",
	"scripts": {
		"gen": "bunx --bun prisma generate",
		"migrate": "bunx --bun prisma migrate dev --create-only",
		"migrate:dev": "bunx --bun prisma migrate dev",
		"push": "bunx --bun prisma db push",
		"db:deploy": "bunx --bun prisma migrate deploy",
		"test:setup": "NODE_ENV=test bunx --bun prisma migrate reset --force",
		"studio": "bunx --bun prisma studio",
		"typecheck": "bunx --bun tsc --noEmit"
	},
	"devDependencies": {
		"@cvsa/prisma-zod": "^3.3.0",
		"@cvsa/typescript-config": "workspace:*",
		"prisma": "^7.6.0",
		"prisma-json-types-generator": "^4.1.1"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.6.0",
		"@prisma/client": "^7.6.0",
		"@types/pg": "^8.16.0",
		"zod": "^4.3.6"
	}
}
</file>

<file path="prisma.config.ts">
// This file was generated by Prisma, and assumes you run Prisma commands using `bun --bun run prisma [command]`.
import { defineConfig, env } from "prisma/config";

export default defineConfig({
	schema: "prisma/",
	migrations: {
		path: "prisma/migrations",
	},
	datasource: {
		url: env("DATABASE_URL"),
	},
});
</file>

<file path="README.md">
# @cvsa/db

## Available Scripts

- `gen` – Generate Prisma client and schema artifacts
- `deploy` – Deploy database changes
- `migrate` – Create a new migration file without applying it
- `migrate:dev` – Apply migrations to the development database
- `push` – Push schema changes directly to the database
- `test:setup` – Reset and apply migrations for test environment
- `studio` – Open Prisma Studio database GUI
</file>

