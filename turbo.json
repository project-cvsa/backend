{
	"remoteCache": {
		"enabled": true
	},
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".output/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {},
		"test": {},
		"test:coverage": {},
		"setup": {
			"cache": false,
			"dependsOn": ["@cvsa/db#push", "@cvsa/db#test:setup", "@cvsa/db#gen"]
		},
		"@cvsa/db#test:setup": {
			"cache": false
		},
		"@cvsa/db#push": {
			"cache": false
		},
		"@cvsa/db#gen": {
			"cache": false
		}
	}
}
