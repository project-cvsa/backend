{
    "compilerOptions": {
        "target": "ESNext",
        "lib": ["ESNext"],
        "module": "preserve",
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "isolatedModules": true,
        "incremental": true,
        "resolveJsonModule": true,
        "paths": {
            "@common/*": ["./src/common/*"],
            "@modules/*": ["./src/modules/*"],
            "@lib/*": ["./src/lib/*"],
            "@/*": ["./src/*"]
        }
    }
}
