{
	"name": "cvsa",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "bunx --bun turbo run dev",
		"build": "bunx --bun turbo run build",
		"lint": "bunx --bun turbo run lint",
		"lint:fix": "biome check --write --unsafe .",
		"format": "biome format --write .",
		"test": "bunx --bun turbo run test",
		"test:coverage": "bunx --bun turbo run test:coverage",
		"typecheck": "bunx --bun turbo typecheck",
		"db:deploy": "bunx --bun turbo db:deploy"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "^1.3.10",
		"turbo": "^2.8.18",
		"typescript": "^6.0.2"
	},
	"packageManager": "bun@1.3.11"
}
